@{
    ViewData["Title"] = "Roles Panel";
}
@model RolesPanelViewModel

<div class="w-full h-full flex">
    @Html.Partial("_Navbar")
    <div class="w-full h-full flex flex-col items-center gap-8 bg-gray-300">
        @if (TempData["Error"] != null)
        {
            <div class="absolute w-[85%] max-w-116 p-3 top-4 right-4 text-sm text-red-800 bg-red-100 border border-red-400 rounded-lg flex justify-between items-center z-10 " role="alert">
                <span class="text-sm">@TempData["Error"]</span>
                <button onclick="this.parentElement.remove()" class="text-red-800 hover:text-red-900 font-bold text-lg leading-none hover:cursor-pointer">&times;</button>
            </div>
        }
        <div class="w-[94%] flex items-center justify-between bg-white shadow-md p-4 mt-8">   
            <form asp-controller="Role" asp-action="SearchRoles" method="post" class="flex items-center gap-2 w-full max-w-md">
                <input name="Search" value="@Model.Search" type="text" placeholder="Search" class="w-full px-3 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>
                <button type="submit" class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Search</button>
            </form>
            <div class="w-1/2 h-full flex justify-end gap-3"> 
                <a asp-action="RolesCreatePanel" asp-controller="Role" class="bg-white hover:bg-gray-100 text-black font-semibold rounded-lg shadow-sm px-5 border border-gray-300 hover:cursor-pointer">Create</a>
            </div>
        </div>
        <div class="w-[94%] h-[82%] flex flex-col gap-2 bg-white shadow-md p-4 mx-5">
            <p class="text-left text-md font-bold text-black">Role Name</p>
            <div class="overflow-y-auto max-h-[93%]">
                <table class="min-w-full">
                    <tbody class="font-semibold text-gray-700 text-md">
                        @if (Model.Roles != null && Model.Roles.Any()) 
                        {
                            @for (int i = 0; i < Model.Roles.Count(); i++)
                            {
                                var roles = Model.Roles[i];
                                @if (roles.Name != "Manager")
                                {
                                    var rowClass = i % 2 == 0 ? "bg-gray-200" : "bg-gray-100";

                                    <tr class="@rowClass even:bg-white hover:bg-gray-300 hover:cursor-pointer">
                                        <td class="px-6 py-3">@roles.Name</td>
                                        <td class="px-6 py-3 space-x-2 text-right">
                                            <form asp-action="DeleteRole" asp-controller="Role" method="post">
                                                <input type="hidden" name="roleId" value="@roles.RoleId" />
                                                <a asp-action="RolesEditPanel" asp-controller="Role" asp-route-roleId="@roles.RoleId" class="h-[25px] text-sm bg-white hover:bg-gray-100 text-black font-semibold px-6 py-0.75 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Edit</a>
                                                <button type="submit" class="bg-white hover:bg-gray-100 text-black font-semibold px-4 py-0.75 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="px-6 py-4 text-left font-semibold text-gray-500">
                                    No roles found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>