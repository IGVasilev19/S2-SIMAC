@using NotificationApp.Models
@{
    ViewData["Title"] = "Sign in";
}
@model LogInViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="bg-custom-gradient flex h-full w-full flex-col items-center justify-center">
    <div class="rounded-4xl flex items-center justify-center border border-white/20 bg-white/10 p-10 shadow-xl backdrop-blur-md md:w-[85%] md:h-[85%]">
        <img src="/images/simac-logo-removebg.png" asp-append-version="true"/>
        <form asp-action="LogIn" asp-controller="Access" method="post" class="flex h-full w-[50%] flex-col items-center">
            <h1 class="mt-[20%] text-4xl font-bold text-white max-md:mt-[30%]">Sign in</h1>
            
            <h2 class="mt-[7%] text-xl font-bold text-white">Email</h2>
            @if (ViewBag.Error != null)
            {
                <span class="text-red-500">
                    @ViewBag.Error
                </span>

            }
            <span asp-validation-for="Email" class="text-red-500"></span>
            <span asp-validation-for="Password" class="text-red-500"></span>
            <input asp-for="Email" class="mt-[3%] h-[8%] w-[60%] rounded-md border border-gray-300 bg-white p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none"/>
            <h2 class="mt-[7%] text-xl font-bold text-white">Password</h2>
            <input asp-for="Password" class="mt-[3%] h-[8%] w-[60%] rounded-md border border-gray-300 bg-white p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none" />
            <button type="submit" class="mt-[8%] h-[8%] w-[45%] rounded bg-blue-400 text-lg font-bold text-white hover:scale-[1.02]">Sign in</button>
        </form>
    </div>
</div>

