@{
    ViewData["Title"] = "Inbox";
}

<div class="w-full h-full flex">
    <div class="h-full bg-custom-gradient flex flex-col items-center justify-between px-5 w-[200px]">
        <div class="flex flex-col gap-20">
            <img src="/images/simac-logo-removebg.png" asp-append-version="true"/>
            <div class="flex flex-col gap-4 mt-[80px]">
                <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Inbox</button>
                <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Analytics</button>
                <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Device</button>
                <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Account</button>
                <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Roles</button>
            </div>
        </div>
        <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold mb-[10%] hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Sign out</button>
    </div>
    <div class="w-full h-full flex flex-col items-center gap-8 bg-gray-300">
        <div class="w-[94%] flex items-center justify-between bg-white shadow-md p-4 mt-8">   
            <div class="flex items-center gap-2 w-full max-w-md">
                <input type="text" placeholder="Search" class="w-full px-3 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>
                <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Search</button>
            </div>
            <button class="bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Sort</button>
        </div>
        <div class="w-[94%] h-[82%] flex gap-3">
            <div class="h-full flex flex-col items-center bg-white">
                <div class="w-[200px] h-[75px] border border-gray-400 rounded mx-2 mt-2 flex items-center justify-center">
                    <div class="w-2/3 h-2/3 border rounded-4xl">
                    </div>
                </div>
            </div>
            <div class="w-full h-full flex flex-col items-center gap-5">
                <div class="w-full flex items-center justify-between bg-white shadow-md p-4">
                    <h1 class="text-black text-xl font-semibold">Selected notification title</h1>
                    <p>15:45 Monday 24 February 2025</p>
                </div>
