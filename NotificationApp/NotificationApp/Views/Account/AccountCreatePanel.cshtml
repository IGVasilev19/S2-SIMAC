@{
    ViewData["Title"] = "Account Create panel";
}

<div class="w-full h-full flex">
    @Html.Partial("_Navbar")
    <div class="w-full h-full flex items-center justify-center bg-gray-300">
        <div class="w-[94%] h-[92%] bg-white shadow-md flex flex-col justify-center items-center gap-8  ">
            <p class="text-4xl font-semibold">Create account</p>
            <div class="flex flex-col w-[800px] h-[60px] justify-center gap-2">
                <p class="select-none">Name*</p>
                <input type="text"
                       name="Name"
                       required
                       minlength="1"
                       class="w-[800px] h-[40px] bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none" />
            </div>
            <div class="flex flex-col w-[800px] h-[60px] justify-center gap-2">
                <p class="select-none">Email*</p>
                <input type="email"
                       name="Email"
                       required
                       class="w-[800px] h-[40px] bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none" />
            </div>
            <div class="flex flex-col w-[800px] h-[60px] justify-center gap-2">
                <p class="select-none">Password*</p>
                <input type="password"
                       name="Password"
                       required
                       class="w-[800px] h-[40px] bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none" />
            </div>
            <div class="flex flex-col w-[800px] h-[60px] gap-2">
                <p class="select-none">Role*</p>
                <input type="text"
                       name="Role"
                       required
                       class="w-[800px] h-[40px] items-center justify-center bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none" />
            </div>
            <button class="w-[800px] h-[40px] bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Save</button> 
        </div>
    </div>
</div>