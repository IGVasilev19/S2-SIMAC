@{
    ViewData["Title"] = "Admin Create/Edit panel";
}

<div class="w-full h-full flex">
    <div class="h-full bg-custom-gradient flex flex-col items-center justify-between px-5 w-[200px]">
        <div class="flex flex-col">
            <img src="/images/simac-logo-removebg.png" asp-append-version="true"/>
            <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold mt-[150px]">Admin</button>
        </div>
        <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold mb-[10%] hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Sign out</button>
    </div>
    <div class="w-full h-full flex items-center justify-center bg-gray-300">
        <div class="w-[94%] h-[92%] bg-white shadow-md flex flex-col justify-center items-center gap-5">
            <p class="text-4xl font-semibold">Create/Edit client</p>
            <div class="w-[800px] flex flex-col gap-2 justify-center">
                <p class="text-lg">Client Name*</p>
                <input class="w-full h-[60px] bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none"/>
            </div>
            <div class="w-[800px] flex flex-col gap-2 justify-center">
                <p class="text-lg">Location*</p>
                <input class="w-full h-[60px] bg-white border border-gray-300 rounded-md p-2 transition duration-300 ease-in-out focus:scale-[1.02] focus:outline-none"/>
            </div>
            <button class="w-[800px] h-[60px] rounded border-2 text-lg text-black font-bold hover:scale-[1.02]">Create</button> 
    </div>
</div>