@{
    ViewData["Title"] = "Account Panel";
}

<div class="w-full h-full flex">
    @Html.Partial("_Navbar")
    <div class="w-full h-full flex flex-col items-center gap-8 bg-gray-300">
        <div class="w-[94%] flex items-center justify-between bg-white shadow-md p-4 mt-8">   
            <div class="flex items-center gap-2 w-full max-w-md">
                <input type="text" placeholder="Search" class="w-full px-3 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>
                <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Search</button>
            </div>
            <a asp-action="AccountCreateEditPanel" aps-controller="System" class="bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Create Account</a>
        </div>
        <div class="w-[94%] h-[82%] bg-white shadow-md p-4 mx-5">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-white">
                        <tr>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Account Name</th>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Role</th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="font-semibold text-gray-700 text-sm">
                        <tr class="bg-gray-100 even:bg-white">
                            <td class="px-6 py-3">Account Name</td>
                            <td class="px-6 py-3">Role</td>
                            <td class="px-6 py-3 space-x-2 text-right">
                                <a asp-action="AccountCreateEditPanel" asp-controller="System" class="bg-white hover:bg-gray-100 text-black font-semibold px-8 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Edit</a>
                                <button class="bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer">Delete</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>