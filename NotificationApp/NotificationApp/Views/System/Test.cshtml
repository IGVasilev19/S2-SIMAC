@{
    ViewData["Title"] = "Test";
}

<body class="flex items-center justify-center h-screen bg-gray-100">

  <div class="relative group w-80 h-48 bg-white shadow-md rounded-lg p-4 border border-gray-300 overflow-hidden">
    <p class="text-gray-700">Hover over this box</p>

    <!-- Animated Buttons -->
    <div class="absolute inset-x-0 flex justify-center transform translate-y-full opacity-0 group-hover:translate-y-1/2 group-hover:opacity-100 transition-all duration-500">
      <div class="flex gap-4">
        <button class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">Edit</button>
        <button class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">Delete</button>
      </div>
    </div>

  </div>

</body>