@{
    ViewData["Title"] = "Devices Panel";
}

<div class="flex h-full w-full">
    @Html.Partial("_Navbar")
    <div class="flex h-full w-full flex-col items-center gap-8 bg-gray-300">
        <div class="mt-8 flex w-[94%] items-center justify-between bg-white p-4 shadow-md">   
            <div class="flex w-full max-w-md items-center gap-2">
                <input type="text" placeholder="Search" class="placeholder-gray-400 w-full border border-gray-300 px-3 focus:outline-none focus:border-gray-400"/>
                <button class="rounded-lg bg-blue-300 px-10 font-semibold text-white shadow-md transition-all duration-150 hover:bg-blue-200 hover:cursor-pointer">Search</button>
            </div>
        </div>
        <div class="w-[94%] h-[82%] bg-white shadow-md p-4 mx-5">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-white">
                        <tr>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Device Name</th>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Location</th>
                            <th class="text-right px-6 py-3 text-sm font-bold text-black pr-25">Status</th>
                        </tr>
                    </thead>
                    <table class="w-full text-sm text-left text-gray-700 font-semibold">
                        <tbody class="group">
                            <tr class="relative bg-gray-100 hover:bg-gray-200 even:bg-white hover:cursor-pointer">
                                <!-- Row Content -->
                                <td class="px-6 py-3">Device Name</td>
                                <td class="px-6 py-3">Location</td>
                                <td class="px-6 py-3 pr-13 flex justify-end relative overflow-hidden">
                                    <div class="flex gap-2 items-center">
                                        <div class="bg-green-500 w-[25px] h-[25px] shadow-md rounded-full"></div>
                                            <p class="font-bold">Online</p>
                                    </div>

                                    <!-- Slide-up Buttons -->
                                    <div class="absolute inset-0 pr-3 flex justify-end items-center transform translate-y-full opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 bg-opacity-80">
                                        <div class="flex gap-2">
                                            <a asp-action="DevicesCreateEditPanel" asp-controller="System" class="h-[30px] text-sm bg-white hover:bg-gray-100 text-black font-semibold rounded-lg shadow-sm px-5 border border-gray-300 hover:cursor-pointer flex justify-center items-center">Edit</a>
                                            <button class="h-[30px] text-sm bg-white hover:bg-gray-100 text-black font-semibold rounded-lg shadow-sm px-5 border border-gray-300 hover:cursor-pointer">Delete</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </table>
            </div>
        </div>
    </div>
</div>