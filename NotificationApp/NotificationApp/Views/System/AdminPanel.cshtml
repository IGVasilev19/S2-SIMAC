@{
    ViewData["Title"] = "Admin panel";
}

<div class="w-full h-full flex">
    <div class="h-full bg-custom-gradient flex flex-col items-center justify-between px-5 w-[200px]">
        <div class="flex flex-col gap-20">
            <img src="/images/simac-logo-removebg.png" asp-append-version="true"/>
            <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold mt-[150px]">Admin</button>
        </div>
        <button class="w-full h-[40px] bg-white/20 backdrop-blur-md rounded-sm shadow-xl border border-white/10 flex items-center justify-center text-md text-gray-200 font-semibold mb-[10%] hover:cursor-pointer transition duration-100 ease-in-out hover:scale-[1.05]">Sign out</button>
    </div>
    <div class="w-full h-full flex flex-col items-center gap-8 bg-gray-300">
        <div class="w-[94%] flex items-center justify-between bg-white shadow-md p-4 mt-8">   
            <div class="flex items-center gap-2 w-full max-w-md">
                <input type="text" placeholder="Search" class="w-full px-3 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>
                <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-md shadow-md transition-all duration-150 hover:cursor-pointer">Search</button>
            </div>
            <button class="bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-md shadow-sm border border-gray-300 hover:cursor-pointer">Create</button>
        </div>
        <div class="w-[94%] h-[82%] bg-white shadow-md p-4 mx-5">
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-white">
                        <tr>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Client Name</th>
                            <th class="text-left px-6 py-3 text-sm font-bold text-black">Assigned Manager</th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="font-semibold text-gray-700 text-sm">
                        <tr class="bg-gray-100 even:bg-white">
                            <td class="px-6 py-3">Client Name</td>
                            <td class="px-6 py-3">Manager Name</td>
                            <td class="px-6 py-3 space-x-2 text-right">
                                <button class="bg-white hover:bg-gray-100 text-black font-semibold px-8 rounded-md shadow-sm border border-gray-300 hover:cursor-pointer">Edit</button>
                                <button class="bg-white hover:bg-gray-100 text-black font-semibold px-6 rounded-md shadow-sm border border-gray-300 hover:cursor-pointer">Delete</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>