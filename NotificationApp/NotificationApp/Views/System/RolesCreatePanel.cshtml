@{
    ViewData["Title"] = "Roles Create panel";
}
@using NotificationApp.Models
@model RoleCreateEditPanelViewModel

<div class="w-full h-full flex">
@Html.Partial("_Navbar")
    <form asp-action="CreateRole" asp-controller="System" method="post" class="w-full h-full flex flex-col items-center gap-4 bg-gray-300">
        <div class="w-[94%] h-[93%] flex flex-col items-center gap-6">
            <div class="w-full flex items-center justify-center bg-white gap-2 shadow-md p-4 mt-2">   
                <p class="w-fit text-md font-semibold m-0 text-black">Role Name: </p>
                <input asp-for="RoleName" type="text" placeholder="Type role name" class="w-[600px] px-2 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>          
            </div>
            <div class="w-full h-full bg-white shadow-md p-4 mx-5">
                <div class="w-full h-full flex flex-col items-center gap-5">
                        <div class="flex w-full justify-center items-center gap-2">
                            <input type="text" placeholder="Search permission" class="w-[600px] px-3 placeholder-gray-400 border border-gray-300 focus:outline-none focus:border-gray-400"/>
                            <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Search</button>
                        </div>
                    <table class="w-[650px]">
                        <tbody>
                            <tr class="flex w-full flex-col justify-center">
                                <td>
                                    <div class="border-b py-1.5 flex justify-between items-center">
                                        <div>
                                            <input type="checkbox" class="w-[20px] bg-white hover:bg-gray-100 text-black font-semibold px-8 py-2 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer" />
                                            <label
                                                class="inline-block ps-[0.15rem] hover:cursor-pointer">
                                                Inbox
                                            </label>
                                        </div>
                                        <button class="flex hover:cursor-pointer justify-center items-center pr-1">
                                            <img src="../images/plus.svg" class="h-[15px]"/>
                                        </button>
                                    </div>
                                </td>  
                            </tr>
                            <tr class="flex w-full flex-col justify-center">
                                <td>
                                    <div class="border-b py-1.5 flex justify-between items-center">
                                        <div>
                                            <input type="checkbox" class="w-[20px] bg-white hover:bg-gray-100 text-black font-semibold px-8 py-2 rounded-lg shadow-sm border border-gray-300 hover:cursor-pointer" />
                                            <label
                                                class="inline-block ps-[0.15rem] hover:cursor-pointer">
                                                Analytics
                                            </label>
                                        </div>
                                        <button class="flex hover:cursor-pointer justify-center items-center pr-1">
                                            <img src="../images/plus.svg" class="h-[15px]"/>
                                        </button>
                                    </div>
                                </td>
                            </tr> 
                        </tbody> 
                    </table>
                </div>
            </div>
        </div>
        <div class="w-[94%] h-fit flex justify-end items-center gap-2">
            <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Discard</button>
            <button class="bg-blue-300 hover:bg-blue-200 text-white font-semibold px-10 rounded-lg shadow-md transition-all duration-150 hover:cursor-pointer">Save</button>            
        </div>
    </form>
    
</div>